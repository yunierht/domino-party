{
  "expo": {
    "name": "Domino Party",
    "slug": "domino-party",
    "version": "1.0.1",
    "scheme": "dominoparty",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yht.dominoparty",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.yht.dominoparty",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#18113A",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0C0E12"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4ca6648b-ec5a-4b08-b425-519db3c4ebd7"
      }
    },
    "owner": "yunierht"
  }
}
